@model HospitalApp.Models.RegistroPacienteViewModel

@{
    ViewData["Title"] = "Registro de Paciente";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">🏥 Crear Cuenta de Paciente</h4>
                </div>
                <div class="card-body p-4">
                    
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold"></div>

                    <form asp-action="AutoRegistro" method="post">
                        
                        <h6 class="text-success fw-bold border-bottom pb-2 mb-3">1. Datos Personales</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Nombre</label>
                                <input asp-for="Nombre" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Apellido Paterno</label>
                                <input asp-for="ApellidoPaterno" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Apellido Materno</label>
                                <input asp-for="ApellidoMaterno" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Fecha Nacimiento</label>
                                <input asp-for="FechaNacimiento" type="date" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Teléfono</label>
                                <input asp-for="Telefono" type="tel" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Correo</label>
                                <input asp-for="Correo" type="email" class="form-control" />
                            </div>
                        </div>

                        <h6 class="text-success fw-bold border-bottom pb-2 mb-3">2. Perfil Médico</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Tipo Sangre</label>
                                <select asp-for="TipoSangre" class="form-select" required>
                                    <option value="">Seleccione</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Peso (kg)</label>
                                <input asp-for="Peso" type="number" step="0.1" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Estatura (m)</label>
                                <input asp-for="Estatura" type="number" step="0.01" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Alergias</label>
                                <input asp-for="Alergias" class="form-control" placeholder="Ej. Penicilina" />
                            </div>
                        </div>

                        <h6 class="text-success fw-bold border-bottom pb-2 mb-3">3. Credenciales de Acceso</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Nombre de Usuario</label>
                                <input asp-for="NombreUsuario" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control" required />
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                                📝 Registrarme como Paciente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>