@model List<HospitalApp.Models.BitacoraViewModel>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-secondary mb-0">📋 Bitácora de Auditoría System</h2>
        <a href="@Url.Action("Index", "Recepcionista")" class="btn btn-outline-secondary fw-bold">
            ⬅️ Volver al Panel
        </a>
    </div>
    <hr />

    @if (ViewBag.ErrorCritico != null) {
        <div class="alert alert-danger">@ViewBag.ErrorCritico</div>
    }

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>ID Registro</th>
                        <th>No. Cita</th>
                        <th>ID Operador</th>
                        <th>Fecha / Hora</th>
                        <th>Estado Asentado</th>
                        <th>Observaciones del Movimiento</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td class="font-monospace text-muted">#@log.IdBitacora.ToString("D4")</td>
                                <td class="fw-bold text-primary">@(log.IdCita.HasValue ? "#" + log.IdCita.Value.ToString("D4") : "N/A")</td>
                                <td>User @log.IdUsuario</td>
                                <td>@log.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>
                                    @if (log.Estado == "Confirmada")
                                    {
                                        <span class="badge bg-success px-2 py-1">Confirmada</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1">@log.Estado</span>
                                    }
                                </td>
                                <td class="small text-muted">@log.Observacion</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No se encontraron registros de auditoría en el sistema.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>