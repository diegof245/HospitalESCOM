@{
    ViewData["Title"] = "Panel de Control - Recepción";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12 text-center text-md-start">
            <h2 class="display-6 fw-bold text-primary">Sistema Hospitalario ESCOM</h2>
            <p class="text-muted">Panel de Control de Recepción. Gestión operativa y administrativa.</p>
            <hr />
        </div>
    </div>

    <div class="row g-4 justify-content-center mb-4">
        <div class="col-md-5">
            <div class="card h-100 shadow-sm hover-shadow border-primary">
                <div class="card-body text-center p-4">
                    <h4 class="card-title fw-bold">Gestión de Citas</h4>
                    <p class="card-text text-muted">Agendar nuevas citas médicas y validar disponibilidad.</p>
                    <a href="@Url.Action("AgendarCita", "Recepcionista")" class="btn btn-primary w-100 py-2 fw-bold">Ingresar a Citas</a>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card h-100 shadow-sm hover-shadow border-success">
                <div class="card-body text-center p-4">
                    <h4 class="card-title fw-bold">Registrar Médico</h4>
                    <p class="card-text text-muted">Alta de nuevos doctores, especialidades y turnos operativos.</p>
                    <a href="@Url.Action("RegistrarDoctor", "Recepcionista")" class="btn btn-success w-100 py-2 fw-bold">Ingresar a Médicos</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 shadow-sm hover-shadow border-warning">
                <div class="card-body text-center p-4">
                    <h4 class="card-title fw-bold">Caja (Cobros)</h4>
                    <p class="card-text text-muted">Procesamiento de pagos por consulta y confirmación de citas.</p>
                    <a href="@Url.Action("Caja", "Recepcionista")" class="btn btn-warning w-100 py-2 fw-bold">Ir a Caja</a>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card h-100 shadow-sm hover-shadow border-secondary">
                <div class="card-body text-center p-4">
                    <h4 class="card-title fw-bold">Bitácora de Auditoría</h4>
                    <p class="card-text text-muted">Visualización de historial de transacciones y movimientos del sistema.</p>
                    <a href="@Url.Action("Bitacora", "Recepcionista")" class="btn btn-secondary w-100 py-2 fw-bold">Ver Auditoría</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12 text-center">
            <span class="badge bg-light text-dark p-2 border">Sesión Activa: @ViewBag.NombreUsuario</span>
        </div>
    </div>
</div>

<style>
    .hover-shadow { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>